# ============================================================
# UK Centre 블로그 분석 자동화 시스템 환경변수
# 이 파일을 .env 로 복사한 후 값을 채워주세요
# cp .env.example .env
# ============================================================

# Claude API (트렌드 분석, 글 생성에 사용)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Naver API (블로그 검색용)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver Blog API (블로그 포스팅용)
NAVER_BLOG_API_CLIENT_ID=your_naver_blog_api_client_id
NAVER_BLOG_API_CLIENT_SECRET=your_naver_blog_api_client_secret
NAVER_BLOG_ACCESS_TOKEN=your_naver_blog_access_token

# Gmail API (credentials.json은 Google Cloud Console에서 다운로드)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Threads API
THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id

# 이메일 발송 (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# 로깅
LOG_LEVEL=INFO
